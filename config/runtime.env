# Defaults used by px4_sitl launch files and helper scripts.
# Override these variables in the shell or roslaunch args when needed.

PX4_SITL_RUNTIME_ROOT=/opt/ros/noetic/share/px4_sitl_1_12/runtime
PX4_SIM_MODEL=iris
PX4_SITL_WORK_ROOT=/tmp/px4_sitl
PX4_SITL_RESET_PARAMS=false

# Optional variables. Define them only when a non-empty value is needed.
# PX4_SITL_PARAM_FILE=/path/to/params
# PX4_SITL_PARAM_BSON=/path/to/parameters.bson
# PX4_SYS_AUTOSTART=10016
# PX4_SIM_SPEED_FACTOR=1
# PX4_HOME_LAT=47.397742
# PX4_HOME_LON=8.545594
# PX4_UXRCE_DDS_NS=px4_1
# PX4_UXRCE_DDS_PORT=8888
