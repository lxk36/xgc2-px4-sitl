# Defaults used by px4_sitl launch files and helper scripts.
# Override these variables in the shell or roslaunch args when needed.

PX4_SITL_RUNTIME_ROOT=/opt/ros/noetic/share/px4_sitl_1_14/runtime
PX4_SIM_MODEL=gazebo-classic_iris
PX4_SITL_WORK_ROOT=/tmp/px4_sitl
PX4_SITL_PARAM_FILE=
PX4_SITL_PARAM_BSON=
PX4_SITL_RESET_PARAMS=false
PX4_SYS_AUTOSTART=
PX4_SIM_SPEED_FACTOR=
PX4_HOME_LAT=
PX4_HOME_LON=
PX4_UXRCE_DDS_NS=
PX4_UXRCE_DDS_PORT=
